# Copy to .env and fill in your values (never commit .env)

# Web3Forms — sends order emails to your inbox
# 1. Sign up at https://web3forms.com
# 2. Create a form with your notification email
# 3. Paste your access key:
VITE_WEB3FORMS_ACCESS_KEY=your_web3forms_access_key

# FormSubmit fallback (only if Web3Forms fails) — use token from activation email, not raw email
VITE_FORMSUBMIT_TOKEN=your_formsubmit_token
